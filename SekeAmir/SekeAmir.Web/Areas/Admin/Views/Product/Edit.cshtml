@model Application.DTOs.Shop.EditProductVm
@{
    ViewData["Title"] = "Edit";
}

<div class="col-md-12">
    <div class="card card-success">
        <div class="card-header">
            <h3 class="card-title">ویرایش محصولات</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-12">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <div class="row">
                           

                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="ImageAddress" class="control-label"></label>
                                    <input type="file" asp-for="Image" class="form-control" />
                                    <span asp-validation-for="ImageAddress" class="text-danger"></span>

                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group">
                                    <label asp-for="IsExchange" class="control-label"></label>
                                    <input type="checkbox" asp-for="IsExchange" class="form-control" />
                                    <span asp-validation-for="IsExchange" class="text-danger"></span>

                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group">
                                    <label asp-for="InputType" class="control-label"></label>
                                    <select asp-for="InputType"
                                            asp-items="Html.GetEnumSelectList<Domain.InputType>()"
                                            class="form-control">
                                        <option value="">انتخاب کنید...</option>
                                    </select>
                                    <span asp-validation-for="InputType" class="text-danger"></span>

                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <input type="submit" value="ثبت" class="btn btn-success" />

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


