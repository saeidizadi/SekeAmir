<!DOCTYPE html>
<html lang="fa" dir="rtl" data-theme="@(ViewBag.Theme ?? "gold")">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="icon" type="image/x-icon" href="Img/logo.png">
    <title>@ViewData["Title"] - صرافی طلایی</title>
    <!-- SEO Meta Tags -->
    @await RenderSectionAsync("MetaTags", required: false)
    <!-- Default Meta Tags -->
    @if (!IsSectionDefined("MetaTags"))
    {
        <meta name="description" content="سکه امیر - صرافی معتبر خرید و فروش سکه، طلا، دلار و ارز با بهترین نرخ روز" />
        <meta name="keywords" content="سکه امیر, صرافی سکه امیر, خرید سکه, فروش سکه, خرید طلا, فروش طلا, قیمت دلار, قیمت سکه, صرافی معتبر, سکه صراف امیر" />
        <meta name="author" content="سکه امیر" />
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link href="~/fonts/fontiran.css" rel="stylesheet" />
    <link href="~/css/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/themes.css"/>
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true"/>
</head>
<body>

@RenderBody()

<script src="~/js/theme.js"></script>
<script src="~/js/main.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/chart.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
