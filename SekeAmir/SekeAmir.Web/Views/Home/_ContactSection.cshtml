@model HomeViewModel
@{
    var phone1Array = Model.Contact.Phone1.Split(',');
    var phone2Array = Model.Contact.Phone2.Split(',');
}
<!-- Contact Section -->
<section id="contact" class="contact-section">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-badge">تماس با ما</span>
            <h2 class="section-title">در خدمت شما هستیم</h2>
            <p class="section-description">
                برای مشاوره و انجام معاملات با ما در تماس باشید
            </p>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="contact-card">
                    <div class="contact-icon">
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <h4>آدرس</h4>
                    <p>@Model.Contact.Address</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="contact-card">
                    <div class="contact-icon">
                        <i class="bi bi-telephone"></i>
                    </div>
                    <h4>تلفن</h4>
                    <p dir="ltr">
                        @for (int i = 0; i < phone1Array.Length; i++)
                        {
                            <a class="text-white" href="tel:@phone1Array[i].Replace("-", "")">@phone1Array[i]</a>
                        }
                    </p>
                    <p dir="ltr">
                        @for (int i = 0; i < phone2Array.Length; i++)
                        {
                            <a class="text-white" href="tel:@phone2Array[i].Replace("-", "")">@phone2Array[i]</a>
                        }
                    </p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="contact-card">
                    <div class="contact-icon">
                        <i class="bi bi-clock"></i>
                    </div>
                    <h4>ساعات کاری</h4>
                    <p>@Model.Contact.WorkingHours</p>
                </div>
            </div>
        </div>
    </div>
</section>
