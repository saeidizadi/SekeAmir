@model ExchangeApp.Models.HomeViewModel

<!-- About Section -->
<section id="about" class="about-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="about-image-wrapper">
                    <div class="about-image">
                        <div class="about-pattern"></div>
                        <div class="about-content-box">
                            <i class="bi bi-building"></i>
                            <h4>@Model.CompanyName</h4>
                            <p>از سال ۱۳۸۰</p>
                        </div>
                    </div>
                    <div class="about-badge-box">
                        <div class="about-badge">
                            <i class="bi bi-patch-check-fill"></i>
                            <span>دارای مجوز رسمی بانک مرکزی</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="about-content">
                    <span class="section-badge">درباره ما</span>
                    <h2 class="about-title">
                        بیش از دو دهه
                        <span class="text-gradient">اعتماد و اعتبار</span>
                    </h2>
                    <p class="about-description">
                        @Model.CompanyName با بیش از @Model.YearsOfExperience سال سابقه درخشان در زمینه خرید و فروش ارز، سکه و طلا،
                        یکی از معتبرترین و قدیمی‌ترین صرافی‌های کشور است. ما با تکیه بر اصول حرفه‌ای،
                        صداقت و شفافیت، توانسته‌ایم اعتماد هزاران مشتری را جلب کنیم.
                    </p>

                    <div class="about-features">
                        @foreach (var feature in Model.Features)
                        {
                            <div class="feature-item">
                                <div class="feature-icon">
                                    <i class="bi @feature.Icon"></i>
                                </div>
                                <div class="feature-content">
                                    <h5>@feature.Title</h5>
                                    <p>@feature.Description</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
