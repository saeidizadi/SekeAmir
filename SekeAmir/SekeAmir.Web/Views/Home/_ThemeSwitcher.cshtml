<!-- Theme Switcher -->
<div class="theme-switcher">
    <button class="btn btn-sm theme-btn" onclick="setTheme('gold')" title="طلایی">
        <span class="theme-dot" style="background: linear-gradient(135deg, #D4AF37, #FFD700);"></span>
    </button>
    <button class="btn btn-sm theme-btn" onclick="setTheme('emerald')" title="زمرد">
        <span class="theme-dot" style="background: linear-gradient(135deg, #2E8B57, #50C878);"></span>
    </button>
    <button class="btn btn-sm theme-btn" onclick="setTheme('royal')" title="سلطنتی">
        <span class="theme-dot" style="background: linear-gradient(135deg, #4169E1, #6495ED);"></span>
    </button>
    <button class="btn btn-sm theme-btn" onclick="setTheme('ruby')" title="یاقوت">
        <span class="theme-dot" style="background: linear-gradient(135deg, #9B111E, #E0115F);"></span>
    </button>
</div>
